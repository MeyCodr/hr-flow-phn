// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int    @id @default(autoincrement())
  fullname     String
  staffid      String @unique
  email        String @unique
  division     String
  department   String
  section      String
  designation  String
  worklocation String
  password     String
}
