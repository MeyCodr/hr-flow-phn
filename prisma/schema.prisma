datasource db {
  provider = "mysql"
}

generator client {
  provider   = "prisma-client"
  engineType = "client"
  output     = "../src/generated"
}

model User {
  id           Int      @id @default(autoincrement())
  fullname     String
  staffid      String   @unique
  email        String   @unique
  divisionId   Int?
  departmentId Int?
  sectionId    Int?
  designation  String?
  workLocation String?
  role         Role     @default(STAFF)
  password     String
  attachment   String? // ✅ Profile picture (file path or URL)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  division        Division?        @relation(fields: [divisionId], references: [id])
  department      Department?      @relation(fields: [departmentId], references: [id])
  section         Section?         @relation(fields: [sectionId], references: [id])
  approvals       Approval[]
  forms           FormSubmission[]
  manpowerUploads ManpowerUpload[]

  PasswordResetToken    PasswordResetToken[]
  approvalFlowSteps     ApprovalFlowStep[]
  approvalStepApprovers ApprovalStepApprover[]
}

model Division {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  departments      Department[]
  users            User[]
  ApprovalFlowStep ApprovalFlowStep[]
}

model Department {
  id         Int      @id @default(autoincrement())
  name       String
  divisionId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  division         Division           @relation(fields: [divisionId], references: [id])
  sections         Section[]
  users            User[]
  ApprovalFlowStep ApprovalFlowStep[]
}

model Section {
  id           Int      @id @default(autoincrement())
  name         String
  departmentId Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  department       Department         @relation(fields: [departmentId], references: [id])
  users            User[]
  ApprovalFlowStep ApprovalFlowStep[]
}

model FormType {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g. "Leave Request", "Manpower Requisition"
  description String?
  createdAt   DateTime @default(now())

  // Relations
  submissions FormSubmission[]
  flowSteps   ApprovalFlowStep[]
}

model FormSubmission {
  id          Int        @id @default(autoincrement())
  formTypeId  Int
  createdById Int
  status      FormStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Store flexible form fields (e.g. reasons, dates, details)
  formData Json

  // Relations
  formType    FormType         @relation(fields: [formTypeId], references: [id])
  createdBy   User             @relation(fields: [createdById], references: [id])
  approvals   Approval[]
  attachments FileAttachment[]
}

model FileAttachment {
  id               Int      @id @default(autoincrement())
  formSubmissionId Int
  fileName         String
  filePath         String // stored path or URL
  fileType         String? // MIME type (e.g. application/pdf, image/png)
  uploadedAt       DateTime @default(now())

  // Relation
  formSubmission FormSubmission @relation(fields: [formSubmissionId], references: [id])
}

model ManpowerUpload {
  id           Int      @id @default(autoincrement())
  fileName     String
  fileType     String?
  fileSize     Int
  fileContent  Bytes
  employeeData Json
  recordCount  Int
  uploadedById Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploadedBy User @relation(fields: [uploadedById], references: [id])
}

model ApprovalFlowStep {
  id           Int      @id @default(autoincrement())
  formTypeId   Int
  order        Int
  role         Role
  departmentId Int?
  divisionId   Int?
  sectionId    Int?
  createdAt    DateTime @default(now())

  // Relations
  formType              FormType               @relation(fields: [formTypeId], references: [id])
  department            Department?            @relation(fields: [departmentId], references: [id])
  division              Division?              @relation(fields: [divisionId], references: [id])
  section               Section?               @relation(fields: [sectionId], references: [id])
  approvalStepApprovers ApprovalStepApprover[]
  user                  User?                  @relation(fields: [userId], references: [id])
  userId                Int?
}

model Approval {
  id           Int       @id @default(autoincrement())
  submissionId Int
  approverId   Int
  stepOrder    Int
  status       String
  remarks      String?
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deadline     DateTime? // 5-day deadline
  escalated    Boolean   @default(false) // has escalation occurred?

  approver   User           @relation(fields: [approverId], references: [id])
  submission FormSubmission @relation(fields: [submissionId], references: [id])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ApprovalStepApprover {
  id     Int @id @default(autoincrement())
  stepId Int
  userId Int

  step ApprovalFlowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  user User             @relation(fields: [userId], references: [id])

  @@unique([stepId, userId])
}

model SexualHarassmentReport {
  id               Int                          @id @default(autoincrement())
  status           SexualHarassmentReportStatus @default(SUBMITTED)
  reporterName     String
  reporterContact  String // phone or email - required
  reporterEmail    String?
  isStaff          Boolean                      @default(true)
  staffId          String?
  workLocation     String?
  divisionName     String?
  departmentName   String?
  sectionName      String?
  reportAs         String? // Victim or Witness
  perpetratorName  String? // a. Nama Pelaku
  victimName       String? // b. Nama Mangsa
  incidentLocation String? // c. Tempat Kejadian
  incidentDateTime String? // d. Tarikh / Masa kejadian
  description      String                       @db.Text // e. Maklumat Kejadian
  witnessName      String? // f. Nama saksi (jika ada)
  evidenceType     String? // Physical, Non-Physical, or None
  caseNotes        String?                      @db.Text
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  // Relations
  attachments SexualHarassmentAttachment[]
}

model SexualHarassmentAttachment {
  id         Int      @id @default(autoincrement())
  reportId   Int
  fileName   String
  filePath   String // path under storage/sensitive-uploads
  fileType   String?
  uploadedAt DateTime @default(now())

  // Relation
  report SexualHarassmentReport @relation(fields: [reportId], references: [id])
}

enum SexualHarassmentReportStatus {
  SUBMITTED
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum Role {
  STAFF
  HEAD_OF_SECTION
  HEAD_OF_DEPARTMENT
  HEAD_OF_DIVISION
  TOP_MANAGEMENT
  ADMIN
  COMPLIANCE_ADMIN
}

enum FormStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  WAITING
  KIV
}
