<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>{{subject}}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>

  <body style="margin:0;padding:0;background-color:#f8f9fa;font-family:Arial,Helvetica,sans-serif;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f8f9fa;padding:20px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;background-color:#ffffff;border-radius:8px;border:1px solid #dddddd;">

            <!-- Header -->
            <tr>
              <td align="center" style="
                padding:20px;
                font-size:20px;
                font-weight:bold;
                color:#ffffff;
                border-radius:8px 8px 0 0;
                {{#if isUnderReview}}background-color:#004aad;{{/if}}
                {{#if isResolved}}background-color:#198754;{{/if}}
                {{#if isClosed}}background-color:#dc3545;{{/if}}
              ">
                {{#if isUnderReview}}Update on Your Report: Under Review{{/if}}
                {{#if isResolved}}Update on Your Report: Resolved{{/if}}
                {{#if isClosed}}Update on Your Report: Closed{{/if}}
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding:25px;color:#333333;font-size:14px;line-height:1.6;">

                <p style="margin:0 0 12px 0;">Dear {{recipientName}},</p>

                <p style="margin:0 0 20px 0;">
                  {{#if isUnderReview}}
                    We would like to inform you that your sexual harassment report (Case #{{reportId}}) has been <strong>acknowledged</strong> and is now under active review by our compliance team.
                  {{/if}}
                  {{#if isResolved}}
                    We would like to inform you that your sexual harassment report (Case #{{reportId}}) has been <strong>resolved</strong>. Our compliance team has completed the review process.
                  {{/if}}
                  {{#if isClosed}}
                    We would like to inform you that your sexual harassment report (Case #{{reportId}}) has been <strong>closed</strong>. Please refer to the case notes below for further information.
                  {{/if}}
                </p>

                <h2 style="color:#004aad;font-size:16px;margin:0 0 10px 0;">Case Summary</h2>

                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;margin-bottom:16px;">
                  <tr>
                    <td style="padding:8px 10px;border-bottom:1px solid #e0e0e0;font-weight:bold;color:#555555;width:35%;vertical-align:top;">Case Reference:</td>
                    <td style="padding:8px 10px;border-bottom:1px solid #e0e0e0;vertical-align:top;">#{{reportId}}</td>
                  </tr>
                  <tr>
                    <td style="padding:8px 10px;border-bottom:1px solid #e0e0e0;font-weight:bold;color:#555555;vertical-align:top;">Reported By:</td>
                    <td style="padding:8px 10px;border-bottom:1px solid #e0e0e0;vertical-align:top;">{{reporterName}} ({{staffId}})</td>
                  </tr>
                  <tr>
                    <td style="padding:8px 10px;border-bottom:1px solid #e0e0e0;font-weight:bold;color:#555555;vertical-align:top;">Department:</td>
                    <td style="padding:8px 10px;border-bottom:1px solid #e0e0e0;vertical-align:top;">{{department}}</td>
                  </tr>
                  <tr>
                    <td style="padding:8px 10px;border-bottom:1px solid #e0e0e0;font-weight:bold;color:#555555;vertical-align:top;">Date Submitted:</td>
                    <td style="padding:8px 10px;border-bottom:1px solid #e0e0e0;vertical-align:top;">{{submittedAt}}</td>
                  </tr>
                  <tr>
                    <td style="padding:8px 10px;border-bottom:1px solid #e0e0e0;font-weight:bold;color:#555555;vertical-align:top;">Date Updated:</td>
                    <td style="padding:8px 10px;border-bottom:1px solid #e0e0e0;vertical-align:top;">{{updatedAt}}</td>
                  </tr>
                  <tr>
                    <td style="padding:8px 10px;border-bottom:1px solid #e0e0e0;font-weight:bold;color:#555555;vertical-align:top;">Current Status:</td>
                    <td style="padding:8px 10px;border-bottom:1px solid #e0e0e0;vertical-align:top;">
                      {{#if isUnderReview}}
                        <span style="display:inline-block;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:bold;background-color:#dbeafe;color:#1d4ed8;">UNDER REVIEW</span>
                      {{/if}}
                      {{#if isResolved}}
                        <span style="display:inline-block;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:bold;background-color:#dcfce7;color:#15803d;">RESOLVED</span>
                      {{/if}}
                      {{#if isClosed}}
                        <span style="display:inline-block;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:bold;background-color:#fee2e2;color:#b91c1c;">CLOSED</span>
                      {{/if}}
                    </td>
                  </tr>
                </table>

                {{#if caseNotes}}
                <div style="background-color:#f8f9fa;border-left:4px solid #004aad;padding:12px 16px;margin-bottom:20px;border-radius:0 4px 4px 0;">
                  <div style="font-weight:bold;color:#004aad;font-size:12px;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Notes from Compliance Officer</div>
                  <p style="margin:0;font-size:13px;color:#444444;">{{caseNotes}}</p>
                </div>
                {{/if}}

                <p style="margin:0 0 20px 0;">
                  {{#if isUnderReview}}
                    You do not need to take any action at this time. Our team will contact you if additional information is needed. Please keep this email for your records.
                  {{/if}}
                  {{#if isResolved}}
                    If you have any concerns about the resolution of your case, please contact the HR department directly. Please keep this email for your records.
                  {{/if}}
                  {{#if isClosed}}
                    If you believe this decision was made in error or have additional information to provide, please contact the HR department directly.
                  {{/if}}
                </p>

                <p style="margin:0;">Thank you,<br />PHN Compliance Team</p>

              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="background-color:#f0f0f0;color:#555555;padding:15px;text-align:center;font-size:12px;line-height:1.4;border-radius:0 0 8px 8px;">
                This is a confidential, automated message regarding your sexual harassment report. Please do not reply to this email.
                Your report is handled with strict confidentiality.
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
